{
  "manifest_version": 3,
  "name": "Aura — AI on Every Page",
  "version": "1.0.0",
  "description": "AI superpowers on any webpage. Summarize, explain code, draft replies, and create posts instantly.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Aura AI"
  }
}
